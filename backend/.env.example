# =========================
# SERVER
# =========================
PORT=8000
NODE_ENV=production

# =========================
# DATABASE
# =========================
MONGO_URI=YOUR_MONGODB_URI

# =========================
# AUTH
# =========================
ACCESS_TOKEN_SECRET=YOUR_STRONG_ACCESS_TOKEN_SECRET
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_SECRET=YOUR_STRONG_REFRESH_TOKEN_SECRET
REFRESH_TOKEN_EXPIRE=7d

# =========================
# CORS
# =========================
CORS_ORIGINS=https://moneymatrixapp.com

# =========================
# TATUM
# =========================
TATUM_API_KEY=YOUR_TATUM_API_KEY
TATUM_WEBHOOK_SECRET=YOUR_TATUM_WEBHOOK_SECRET
TATUM_WEBHOOK_HMAC_SECRET=YOUR_TATUM_HMAC_SECRET
TATUM_TRON_ADMIN_ADDRESS=YOUR_ADMIN_TRON_ADDRESS
TATUM_TRON_ADMIN_SIGNATURE_ID=YOUR_TATUM_TRON_ADMIN_SIGNATURE_ID
TATUM_TRON_ADMIN_SIGNER_REF=treasury-mainnet-tron
ALLOW_MNEMONIC_SIGNER_IN_PRODUCTION=false
TATUM_TRON_TRANSFER_MODE=TRX
TATUM_TRON_TRC20_TOKEN_ADDRESS=

# =========================
# TRANSAK
# =========================
TRANSAK_API_KEY=YOUR_TRANSAK_API_KEY
TRANSAK_API_SECRET=YOUR_TRANSAK_API_SECRET
TRANSAK_ACCESS_TOKEN=
TRANSAK_HOST_URL=https://moneymatrixapp.com
TRANSAK_REFERRER_DOMAIN=moneymatrixapp.com

# =========================
# WEBHOOK CONFIG
# =========================
PUBLIC_WEBHOOK_BASE_URL=https://api.moneymatrixapp.com
BACKEND_PUBLIC_URL=https://api.moneymatrixapp.com

# =========================
# REDIS
# =========================
REDIS_URL=redis://127.0.0.1:6379

# =========================
# BLOCKCHAIN SETTINGS
# =========================
TRON_FEE=1
MIN_TRON_CONFIRMATIONS=1

# =========================
# JOB / QUEUE CONFIG
# =========================
WEBHOOK_MAX_RETRIES=5
DEPOSIT_POLL_INTERVAL_MS=120000
DEPOSIT_POLL_BATCH_SIZE=25
WITHDRAWAL_JOB_ATTEMPTS=5
WITHDRAWAL_JOB_BACKOFF_MS=5000
WITHDRAWAL_WORKER_CONCURRENCY=1

# =========================
# ENCRYPTION
# =========================
MENEMONIC_ENCRYPTION_KEY=YOUR_32_BYTE_ENCRYPTION_SECRET

# =========================
# OPTIONAL ADMIN WALLET MAPPING
# =========================
ADMIN_WALLET_USER_ID=
ADMIN_WALLET_USER_EMAIL=
ADMIN_WALLET_USER_PHONE=

# =========================
# ADMIN SIGNUP
# =========================
ADMIN_SIGNUP_KEY=YOUR_ADMIN_SIGNUP_KEY

# =========================
# TWILIO (OPTIONAL)
# =========================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# =========================
# EMAIL
# =========================
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_ALLOW_INVALID_TLS=true
